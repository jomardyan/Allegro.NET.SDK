    #region Stock Management Tests

    [Fact]
    public async Task GetFulfillmentStockAsync_ReturnsStockList()
    {
        // Arrange
        var expectedResponse = new FulfillmentStockList
        {
            Items = new List<FulfillmentStockItem>
            {
                new FulfillmentStockItem { Ean = "1234567890123", Available = 100 },
                new FulfillmentStockItem { Ean = "9876543210987", Available = 50 }
            }
        };
        SetupHttpResponse(HttpStatusCode.OK, expectedResponse);

        // Act
        var result = await _client.GetFulfillmentStockAsync();

        // Assert
        result.Should().NotBeNull();
        result.Items.Should().HaveCount(2);
        result.Items![0].Available.Should().Be(100);
    }

    #endregion

    #region Order Parcels Tests

    [Fact]
    public async Task GetFulfillmentOrderParcelsAsync_ValidOrderId_ReturnsParcels()
    {
        // Arrange
        var orderId = "order-123";
        var expectedResponse = new FulfillmentOrderParcels
        {
            Parcels = new List<FulfillmentParcel>
            {
                new FulfillmentParcel { Id = "parcel-1", TrackingNumber = "TRACK123" }
            }
        };
        SetupHttpResponse(HttpStatusCode.OK, expectedResponse);

        // Act
        var result = await _client.GetFulfillmentOrderParcelsAsync(orderId);

        // Assert
        result.Should().NotBeNull();
        result.Parcels.Should().HaveCount(1);
        result.Parcels![0].TrackingNumber.Should().Be("TRACK123");
    }

    [Fact]
    public async Task GetFulfillmentOrderParcelsAsync_NullOrderId_ThrowsArgumentNullException()
    {
        // Act & Assert
        await Assert.ThrowsAsync<ArgumentNullException>(
            () => _client.GetFulfillmentOrderParcelsAsync(null!));
    }

