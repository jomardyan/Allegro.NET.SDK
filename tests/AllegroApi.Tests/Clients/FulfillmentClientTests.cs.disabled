    [Fact]
    public async Task GetAdvanceShipNoticeReceivingStateAsync_ValidId_ReturnsState()
    {
        // Arrange
        var asnId = "asn-state";
        var expectedResponse = new AdvanceShipNoticeReceivingState
        {
            Status = "RECEIVING"
        };
        SetupHttpResponse(HttpStatusCode.OK, expectedResponse);

        // Act
        var result = await _client.GetAdvanceShipNoticeReceivingStateAsync(asnId);

        // Assert
        result.Should().NotBeNull();
        result.Status.Should().Be("RECEIVING");
