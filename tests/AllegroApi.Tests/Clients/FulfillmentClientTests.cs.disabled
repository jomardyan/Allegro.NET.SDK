using AllegroApi.Clients;
using AllegroApi.Configuration;
using AllegroApi.Http;
using AllegroApi.Models.Fulfillment;
using FluentAssertions;
using Moq;
using Moq.Protected;
using System.Net;
using System.Net.Http.Headers;
using System.Text;
using System.Text.Json;
using Xunit;

namespace AllegroApi.Tests.Clients;

public class FulfillmentClientTests : IDisposable
{
    private readonly Mock<HttpMessageHandler> _mockHttpMessageHandler;
    private readonly HttpClient _httpClient;
    private readonly AllegroHttpClient _allegroHttpClient;
    private readonly FulfillmentClient _client;

    public FulfillmentClientTests()
    {
        _mockHttpMessageHandler = new Mock<HttpMessageHandler>();
        _httpClient = new HttpClient(_mockHttpMessageHandler.Object)
        {
            BaseAddress = new Uri("https://api.allegro.pl")
        };
        var options = new AllegroApiOptions
        {
            AccessToken = "test-token",
            BaseUrl = "https://api.allegro.pl"
        };
        _allegroHttpClient = new AllegroHttpClient(_httpClient, options);
        _client = new FulfillmentClient(_allegroHttpClient);
    }

    public void Dispose()
    {
        _allegroHttpClient?.Dispose();
        GC.SuppressFinalize(this);
    }

    private void SetupHttpResponse<T>(HttpStatusCode statusCode, T? responseObject)
    {
        var json = JsonSerializer.Serialize(responseObject);
        var response = new HttpResponseMessage(statusCode)
        {
            Content = new StringContent(json, Encoding.UTF8, "application/json")
        };

        _mockHttpMessageHandler.Protected()
            .Setup<Task<HttpResponseMessage>>(
                "SendAsync",
                ItExpr.IsAny<HttpRequestMessage>(),
                ItExpr.IsAny<CancellationToken>())
            .ReturnsAsync(response);
    }

    private void SetupHttpResponseWithLocation(HttpStatusCode statusCode, string locationUrl)
    {
        var response = new HttpResponseMessage(statusCode)
        {
            Content = new StringContent("", Encoding.UTF8, "application/json")
        };
        response.Headers.Location = new Uri(locationUrl, UriKind.Relative);

        _mockHttpMessageHandler.Protected()
            .Setup<Task<HttpResponseMessage>>(
                "SendAsync",
                ItExpr.IsAny<HttpRequestMessage>(),
                ItExpr.IsAny<CancellationToken>())
            .ReturnsAsync(response);
    }

    #region Advance Ship Notices Tests

    [Fact]
    public async Task GetAdvanceShipNoticesAsync_ReturnsNoticesList()
    {
        // Arrange
        var expectedResponse = new AdvanceShipNoticeList
        {
            AdvanceShipNotices = new List<AdvanceShipNotice>
            {
                new AdvanceShipNotice { Id = "asn-1", Status = "IN_TRANSIT" },
                new AdvanceShipNotice { Id = "asn-2", Status = "COMPLETED" }
            }
        };
        SetupHttpResponse(HttpStatusCode.OK, expectedResponse);

        // Act
        var result = await _client.GetAdvanceShipNoticesAsync();

        // Assert
        result.Should().NotBeNull();
        result.AdvanceShipNotices.Should().HaveCount(2);
        result.AdvanceShipNotices![0].Status.Should().Be("IN_TRANSIT");
    }

    [Fact]
    public async Task CreateAdvanceShipNoticeAsync_ValidRequest_ReturnsCreatedNotice()
    {
        // Arrange
        var request = new CreateAdvanceShipNoticeRequest
        {
            Name = "Test ASN",
            HandlingUnit = "PALLETS"
        };
        var expectedResponse = new AdvanceShipNoticeResponse
        {
            Id = "asn-123",
            Status = "DRAFT"
        };
        SetupHttpResponse(HttpStatusCode.Created, expectedResponse);

        // Act
        var result = await _client.CreateAdvanceShipNoticeAsync(request);

        // Assert
        result.Should().NotBeNull();
        result.Id.Should().Be("asn-123");
        result.Status.Should().Be("DRAFT");
    }

    [Fact]
    public async Task CreateAdvanceShipNoticeAsync_NullRequest_ThrowsArgumentNullException()
    {
        // Act & Assert
        await Assert.ThrowsAsync<ArgumentNullException>(
            () => _client.CreateAdvanceShipNoticeAsync(null!));
    }

    [Fact]
    public async Task GetAdvanceShipNoticeAsync_ValidId_ReturnsNotice()
    {
        // Arrange
        var asnId = "asn-456";
        var expectedResponse = new AdvanceShipNoticeResponse
        {
            Id = asnId,
            Status = "UNPACKING"
        };
        SetupHttpResponse(HttpStatusCode.OK, expectedResponse);

        // Act
        var result = await _client.GetAdvanceShipNoticeAsync(asnId);

        // Assert
        result.Should().NotBeNull();
        result.Id.Should().Be(asnId);
    }

    [Fact]
    public async Task GetAdvanceShipNoticeAsync_NullId_ThrowsArgumentNullException()
    {
        // Act & Assert
        await Assert.ThrowsAsync<ArgumentNullException>(
            () => _client.GetAdvanceShipNoticeAsync(null!));
    }

    [Fact]
    public async Task UpdateAdvanceShipNoticeAsync_ValidData_CompletesSuccessfully()
    {
        // Arrange
        var asnId = "asn-789";
        var request = new UpdateAdvanceShipNoticeRequest
        {
            Name = "Updated ASN"
        };
        SetupHttpResponse(HttpStatusCode.NoContent, (object?)null);

        // Act
        await _client.UpdateAdvanceShipNoticeAsync(asnId, request);

        // Assert - no exception thrown
    }

    [Fact]
    public async Task UpdateAdvanceShipNoticeAsync_NullId_ThrowsArgumentNullException()
    {
        // Arrange
        var request = new UpdateAdvanceShipNoticeRequest();

        // Act & Assert
        await Assert.ThrowsAsync<ArgumentNullException>(
            () => _client.UpdateAdvanceShipNoticeAsync(null!, request));
    }

    [Fact]
    public async Task UpdateAdvanceShipNoticeAsync_NullRequest_ThrowsArgumentNullException()
    {
        // Act & Assert
        await Assert.ThrowsAsync<ArgumentNullException>(
            () => _client.UpdateAdvanceShipNoticeAsync("asn-id", null!));
    }

    [Fact]
    public async Task CancelAdvanceShipNoticeAsync_ValidId_CompletesSuccessfully()
    {
        // Arrange
        var asnId = "asn-cancel";
        SetupHttpResponse(HttpStatusCode.NoContent, (object?)null);

        // Act
        await _client.CancelAdvanceShipNoticeAsync(asnId);

