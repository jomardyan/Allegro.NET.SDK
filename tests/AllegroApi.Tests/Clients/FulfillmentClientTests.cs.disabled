    [Fact]
    public async Task GetAdvanceShipNoticeLabelsAsync_ValidId_ReturnsLabelData()
    {
        // Arrange
        var asnId = "asn-labels";
        var expectedData = new byte[] { 0x25, 0x50, 0x44, 0x46 }; // PDF header
        var response = new HttpResponseMessage(HttpStatusCode.OK)
        {
            Content = new ByteArrayContent(expectedData)
        };
        response.Content.Headers.ContentType = new MediaTypeHeaderValue("application/pdf");

        _mockHttpMessageHandler.Protected()
            .Setup<Task<HttpResponseMessage>>(
                "SendAsync",
                ItExpr.IsAny<HttpRequestMessage>(),
                ItExpr.IsAny<CancellationToken>())
            .ReturnsAsync(response);

        // Act
        var result = await _client.GetAdvanceShipNoticeLabelsAsync(asnId);

        // Assert
        result.Should().NotBeNull();
        result.Should().HaveCount(4);
    }

    [Fact]
    public async Task GetAdvanceShipNoticeLabelsAsync_NullId_ThrowsArgumentNullException()
    {
        // Act & Assert
        await Assert.ThrowsAsync<ArgumentNullException>(
            () => _client.GetAdvanceShipNoticeLabelsAsync(null!));
    }

